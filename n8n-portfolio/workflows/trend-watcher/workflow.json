    {
      "parameters": {
        "content": "## Fetch Reels\nIterates over the list of creators. Uses Apify to scrape or fetch reels from the specified social media account of each creator.",
        "height": 240,
        "width": 1040
      },
      "type": "n8n-nodes-base.stickyNote",
